# OpenCart MCP Server Configuration
# Copy this to .env and fill in your values.

# ──────────────────────────────────────────────────────────────────
# REMOTE VPS (default)
# Connect to an OpenCart install on a remote server via SSH.
# ──────────────────────────────────────────────────────────────────

OPENCART_SSH_HOST=your-server-ip
OPENCART_SSH_USER=your-ssh-username
OPENCART_SSH_KEY=~/.ssh/id_ed25519

# MySQL database credentials (as configured on the remote server)
OPENCART_DB_USER=your_db_user
OPENCART_DB_PASS=your_db_password
OPENCART_DB_NAME=your_opencart_database

# OpenCart installation paths (on the remote server)
OPENCART_ROOT=/path/to/opencart
OPENCART_STORAGE=/path/to/storage

# Optional: force a specific DB table prefix. If unset, the server reads
# DB_PREFIX from your OpenCart config.php automatically (works for both
# the default 'oc_' and any custom prefix you've configured).
# OPENCART_DB_PREFIX=oc_

# ──────────────────────────────────────────────────────────────────
# LOCAL DDEV (alternative)
# To use an OpenCart install running under DDEV, uncomment below and
# remove the SSH block above. SSH_HOST=ddev triggers DDEV mode.
# Container paths are auto-set to /var/www/html — you only set the
# LOCAL project path via OPENCART_ROOT (used as cwd for ddev commands).
# ──────────────────────────────────────────────────────────────────

# OPENCART_SSH_HOST=ddev
# OPENCART_DB_USER=db
# OPENCART_DB_PASS=db
# OPENCART_DB_NAME=db
# OPENCART_ROOT=/Users/you/Sites/your-opencart-project
